generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  panicPassword String?
  switches  Switch[]
  logs      Log[]
  vaultItems VaultItem[]
}

model Switch {
  id           Int      @id @default(autoincrement())
  name         String
  alertEmail   String
  targetTime   BigInt
  durationMs   BigInt   @default(86400000)
  status       String   @default("ACTIVE")
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  vaultItems   VaultItem[]
}

model VaultItem {
  id        Int        @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime   @default(now())
  userId    Int
  user      User       @relation(fields: [userId], references: [id])
  switches  Switch[]
}

model Log {
  id      Int      @id @default(autoincrement())
  date    DateTime @default(now())
  action  String
  details String
  userId  Int
  user    User     @relation(fields: [userId], references: [id])
}
